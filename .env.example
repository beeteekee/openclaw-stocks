# ==================== 数据源配置 ====================
# Tushare 数据源 token
# 获取方式：https://tushare.pro/
TUSHARE_TOKEN=your_tushare_token_here

# ==================== LLM 配置 ====================
# 智谱AI（GLM-4.7）
# 获取方式：https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Moonshot AI（Kimi）
# 获取方式：https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Kimi Coding API
# 获取方式：https://platform.moonshot.cn/
KIMI_CODING_API_KEY=your_kimi_coding_api_key_here
KIMI_CODING_BASE_URL=https://api.kimi.com/coding/

# OpenRouter
# 获取方式：https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ==================== 飞书配置 ====================
# 飞书应用配置
# 获取方式：https://open.feishu.cn/
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_REGION=cn

# ==================== BettaFish 舆情分析配置 ====================
# BettaFish 服务地址
BETTAFISH_URL=http://localhost:5000

# BettaFish LLM 配置（使用与上面相同的LLM即可）
BETTAFISH_INSIGHT_API_KEY=your_insight_api_key_here
BETTAFISH_INSIGHT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BETTAFISH_INSIGHT_MODEL=glm-4.7

BETTAFISH_MEDIA_API_KEY=your_media_api_key_here
BETTAFISH_MEDIA_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BETTAFISH_MEDIA_MODEL=glm-4.7

BETTAFISH_QUERY_API_KEY=your_query_api_key_here
BETTAFISH_QUERY_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BETTAFISH_QUERY_MODEL=glm-4.7

BETTAFISH_REPORT_API_KEY=your_report_api_key_here
BETTAFISH_REPORT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BETTAFISH_REPORT_MODEL=glm-4.7

# ==================== 数据库配置 ====================
# PostgreSQL 配置（用于BettaFish）
DB_HOST=localhost
DB_PORT=5432
DB_USER=bettafish
DB_PASSWORD=your_db_password_here
DB_NAME=bettafish
DB_DIALECT=postgresql
DB_CHARSET=utf8mb4

# ==================== 服务配置 ====================
# Flask 服务端口
FLASK_PORT=18789

# 统计数据文件路径
STATS_FILE=/Users/likan/.openclaw/workspace/query_stats.json

# TOP3 结果文件路径
TOP3_RESULT_FILE=/Users/likan/.openclaw/workspace/top3_today_result.csv

# ==================== OpenClaw 配置 ====================
# OpenClaw 工作区
OPENCLAW_WORKSPACE=/Users/likan/.openclaw/workspace

# OpenClaw 仓库
OPENCLAW_REPO=https://github.com/beeteekee/openclaw-stocks.git

# ==================== 其他配置 ====================
# 用户邮箱（用于Git提交）
GIT_EMAIL=your_email_here
GIT_NAME=your_name_here
